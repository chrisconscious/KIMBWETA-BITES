# ── KIMBWETA BITES — Environment Configuration ──────────────────
# Copy this file to .env and fill in your values.
#   cp .env.example .env
#
# ── Production Deployment References ─────────────────────────────
# Database:  https://neon.tech (free PostgreSQL)
# Backend:   https://render.com (Web Service)
# Frontend:  https://vercel.com (static hosting)
# Uploads:   https://cloudinary.com or https://supabase.co/storage

# ── App ──────────────────────────────────────────────────────────
NODE_ENV=development
PORT=3000
API_PREFIX=/api/v1

# ── Database ────────────────────────────────────────────────────
# Production: Get connection string from Neon Dashboard → Connection Details
DATABASE_URL="postgresql://user:password@ep-xxxx.us-east-2.aws.neon.tech/kimbweta?sslmode=require"

# ── JWT ─────────────────────────────────────────────────────────
# Production: Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=change_this_to_a_random_64_char_hex_string
JWT_EXPIRES_IN=15m
JWT_REFRESH_SECRET=change_this_to_another_random_64_char_hex_string
JWT_REFRESH_EXPIRES_IN=7d

# ── Redis (optional – leave empty to disable) ───────────────────
REDIS_URL=

# ── CORS ────────────────────────────────────────────────────────
# Production: Add your Vercel frontend URL here
CORS_ORIGINS=http://localhost:3000,http://localhost:3001,https://kimbweta-bites.vercel.app

# ── Rate Limiting ───────────────────────────────────────────────
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=500
OTP_RATE_LIMIT_MAX=10

# ── OTP ─────────────────────────────────────────────────────────
OTP_EXPIRY_MINUTES=10
OTP_LENGTH=6
OTP_MOCK_MODE=true
SMS_PROVIDER=console

# ── Uploads ─────────────────────────────────────────────────────
# Production: Use external storage (Cloudinary/Supabase) for file persistence
# Render / Railway / Docker: Set to ./uploads (files won't persist across restarts)
UPLOAD_DIR=uploads
MAX_FILE_SIZE_MB=5

# ── Logging ─────────────────────────────────────────────────────
LOG_LEVEL=info

# ── Brute Force Protection ──────────────────────────────────────
LOGIN_MAX_ATTEMPTS=5
LOGIN_LOCKOUT_MINUTES=15

# ── Per-role Rate Limits ────────────────────────────────────────
RATE_LIMIT_ANON=30
RATE_LIMIT_CUSTOMER=100
RATE_LIMIT_ADMIN=300
RATE_LIMIT_SUPER_ADMIN=500

# ── File Upload Limits ──────────────────────────────────────────
MAX_VIDEO_SIZE_MB=50

# ── Backup ──────────────────────────────────────────────────────
BACKUP_DIR=./backup

# ── Idempotency ─────────────────────────────────────────────────
IDEMPOTENCY_TTL_MINUTES=60
