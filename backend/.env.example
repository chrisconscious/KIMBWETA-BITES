# ── App ────────────────────────────────────────────────────────
NODE_ENV=development
PORT=3000
API_PREFIX=/api/v1

# ── Database ───────────────────────────────────────────────────
DATABASE_URL="postgresql://DB_USER:DB_PASSWORD@localhost:5432/kimbweta"

# ── JWT ────────────────────────────────────────────────────────
JWT_SECRET=GENERATE_RANDOM_SECRET_HERE
JWT_EXPIRES_IN=15m
JWT_REFRESH_SECRET=kimbweta_refresh_secret_change_in_production_min_32_chars
JWT_REFRESH_EXPIRES_IN=7d

# ── Redis (optional – set to empty to disable) ─────────────────
REDIS_URL=

# ── CORS ───────────────────────────────────────────────────────
CORS_ORIGINS=http://localhost:3001,http://127.0.0.1:3001,http://localhost:5500,http://127.0.0.1:5500

# ── Rate limiting ──────────────────────────────────────────────
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=500
OTP_RATE_LIMIT_MAX=10

# ── OTP ────────────────────────────────────────────────────────
OTP_EXPIRY_MINUTES=10
# In dev: OTP is shown in console, not actually sent via SMS
SMS_PROVIDER=console

# ── Uploads ────────────────────────────────────────────────────
UPLOAD_DIR=uploads
MAX_FILE_SIZE_MB=5

# ── Logging ────────────────────────────────────────────────────
LOG_LEVEL=info
