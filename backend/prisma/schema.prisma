model UserCategoryInterest {
  userId             String   @map("user_id")
  categoryId         String   @map("category_id")
  interestScore      Float    @default(0) @map("interest_score")
  viewCount          Int      @default(0) @map("view_count")
  clickCount         Int      @default(0) @map("click_count")
  purchaseCount      Int      @default(0) @map("purchase_count")
  shareCount         Int      @default(0) @map("share_count")
  favoriteCount      Int      @default(0) @map("favorite_count")
  cartAddCount       Int      @default(0) @map("cart_add_count")
  reviewCount        Int      @default(0) @map("review_count")
  orderCompletedCount Int     @default(0) @map("order_completed_count")
  recencyWeight      Float    @default(1.0) @map("recency_weight")
  updatedAt          DateTime @default(now()) @map("updated_at")

  @@id([userId, categoryId])
  @@index([userId, interestScore(sort: Desc)])
  @@map("user_category_interest")
}

model ProductScore {
  productId        String   @id @map("product_id")
  totalViews       Int      @default(0) @map("total_views")
  totalClicks      Int      @default(0) @map("total_clicks")
  totalPurchases   Int      @default(0) @map("total_purchases")
  totalShares      Int      @default(0) @map("total_shares")
  totalFavorites   Int      @default(0) @map("total_favorites")
  dailyViews       Int      @default(0) @map("daily_views")
  weeklyViews      Int      @default(0) @map("weekly_views")
  monthlyViews     Int      @default(0) @map("monthly_views")
  dailyPurchases   Int      @default(0) @map("daily_purchases")
  weeklyPurchases  Int      @default(0) @map("weekly_purchases")
  monthlyPurchases Int      @default(0) @map("monthly_purchases")
  trendingScore    Float    @default(0) @map("trending_score")
  recencyScore     Float    @default(0) @map("recency_score")
  updatedAt        DateTime @default(now()) @map("updated_at")

  @@index([trendingScore(sort: Desc)])
  @@index([totalViews(sort: Desc)])
  @@map("product_scores")
}

model ShareEvent {
  id               String   @id @default(uuid())
  productId        String   @map("product_id")
  senderUserId     String?  @map("sender_user_id")
  recipientUserId  String?  @map("recipient_user_id")
  clicked          Boolean  @default(false)
  purchased        Boolean  @default(false)
  createdAt        DateTime @default(now()) @map("created_at")

  @@index([productId])
  @@index([recipientUserId])
  @@index([createdAt(sort: Desc)])
  @@map("share_events")
}

model Notification {
  id            String    @id @default(uuid())
  userId        String    @map("user_id")
  title         String
  body          String
  type          String
  referenceId   String?   @map("reference_id")
  referenceType String?   @map("reference_type")
  isRead        Boolean   @default(false) @map("is_read")
  sentAt        DateTime? @map("sent_at")
  createdAt     DateTime  @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([userId, isRead])
  @@map("notifications")
}
