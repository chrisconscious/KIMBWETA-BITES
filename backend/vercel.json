{
  "version": 2,
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "env": {
    "DATABASE_URL": "@database_url",
    "JWT_SECRET": "@jwt_secret",
    "REFRESH_TOKEN_SECRET": "@refresh_token_secret",
    "NODE_ENV": "production"
  },
  "functions": {
    "api/index.ts": {
      "runtime": "@vercel/node@3.x",
      "memory": 1024,
      "maxDuration": 30
    }
  },
  "routes": [
    {
      "src": "/(?!_next).*",
      "dest": "api/index.ts"
    },
    {
      "handle": "filesystem"
    }
  ]
}
